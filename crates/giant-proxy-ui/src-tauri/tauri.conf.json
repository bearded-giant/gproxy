{
  "productName": "Giant Proxy",
  "version": "0.1.0",
  "identifier": "com.giantproxy.ui",
  "build": {
    "frontendDist": "../src"
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.png"
    ],
    "macOS": {
      "minimumSystemVersion": "10.15"
    },
    "linux": {
      "deb": {
        "depends": ["libwebkit2gtk-4.1-0", "libappindicator3-1"]
      }
    }
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "popover",
        "title": "Giant Proxy",
        "width": 400,
        "height": 500,
        "resizable": false,
        "decorations": false,
        "visible": false,
        "skipTaskbar": true
      },
      {
        "label": "dashboard",
        "title": "Giant Proxy Dashboard",
        "url": "dashboard.html",
        "width": 900,
        "height": 650,
        "resizable": true,
        "decorations": true,
        "visible": false,
        "center": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; script-src 'self'; style-src 'self' 'unsafe-inline'"
    }
  }
}
