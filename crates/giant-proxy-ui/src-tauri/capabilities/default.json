{
  "identifier": "default",
  "description": "Default capabilities for Giant Proxy",
  "windows": ["popover", "dashboard"],
  "permissions": [
    "core:default",
    "core:window:default",
    "core:window:allow-show",
    "core:window:allow-hide",
    "core:window:allow-set-focus",
    "core:window:allow-close",
    "core:window:allow-center",
    "core:app:default",
    "shell:allow-open",
    "autostart:default",
    "autostart:allow-is-enabled",
    "autostart:allow-enable",
    "autostart:allow-disable",
    "dialog:default",
    "dialog:allow-open"
  ]
}
